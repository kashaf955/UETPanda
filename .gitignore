# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
**/.next/
**/out/
.next/
out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
trace

# env files — keep templates; never commit real secrets
.env
.env.*
!.env.example
!**/.env.example

# Firebase / GCP credentials (never commit)
scripts/serviceAccountKey.json
**/serviceAccountKey.json
*-firebase-adminsdk*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# turbo
.turbo/
**/.turbo/
